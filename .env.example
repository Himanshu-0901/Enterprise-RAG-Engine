NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
APP_BASE_URL=http://localhost:3001

DATABASE_URL=postgres://rag:rag@localhost:55432/rag_llm
DATABASE_SHARDS_JSON={}
REDIS_URL=redis://localhost:6379

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=rag-documents
S3_ACCESS_KEY_ID=rag
S3_SECRET_ACCESS_KEY=rag-password

EMBEDDING_PROVIDER=deterministic
EMBEDDING_DIMENSIONS=1536
OPENAI_API_KEY=replace-me
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

LLM_PROVIDER=deterministic
OPENAI_GENERATION_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=replace-me
ANTHROPIC_GENERATION_MODEL=claude-3-5-haiku-latest
LLM_MAX_OUTPUT_TOKENS=700
LLM_INPUT_TOKEN_COST_PER_1M=0
LLM_OUTPUT_TOKEN_COST_PER_1M=0

DOCUMENT_PARSER=google_document_ai
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
# For production/local cloud parsing, set GOOGLE_APPLICATION_CREDENTIALS
# to a mounted service-account JSON file path.

STRIPE_SECRET_KEY=replace-me
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

RETENTION_CLEANUP_INTERVAL_MINUTES=1440
