{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@rag-llm/rag": [
        "../../packages/rag/src/index.ts"
      ],
      "@rag-llm/shared": [
        "../../packages/shared/src/index.ts"
      ]
    },
    "incremental": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
